<Window x:Name="Main" x:Class="RePKG_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RePKG_WPF"
        mc:Ignorable="d"
        Title="小红车解包工具" Height="542" Width="814"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        AllowDrop="True"
        Drop="Main_Drop"
        MouseDoubleClick="Main_MouseDoubleClick"
        Background="{DynamicResource MaterialDesignPaper}" FontFamily="Microsoft YaHei UI" Icon="512X512.ico" ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 第一行：两个复选框（居中） -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10,10,10,10">
            <CheckBox x:Name="chkNoTexConvert" Content="不转换图片" Margin="0,0,20,0" FontSize="13"/>
            <CheckBox x:Name="chkOnlyImages" Content="只提取图片" FontSize="13"/>
        </StackPanel>

        <!-- 第二行：已选择文件列表 -->
        <Expander x:Name="expander_file" Header="已选择 0 个对象" Grid.Row="1" Margin="10,10,0,0" FontFamily="Microsoft YaHei UI" BorderBrush="#00FFB1B1" Background="#FFECECEC" MinWidth="630" HorizontalAlignment="Left" Width="630">
            <Grid Background="#FFE5E5E5">
                <ListBox x:Name="lb_list" VerticalAlignment="Top" FontFamily="Microsoft YaHei UI" HorizontalContentAlignment="Stretch"/>
            </Grid>
        </Expander>

        <!-- 第三行：输出目录标签和文本框 -->
        <Label Content="输出目录：" Grid.Row="2" Margin="10,10,0,0" FontSize="16" HorizontalAlignment="Left" Width="80"/>
        <TextBox x:Name="tb_dir" Grid.Row="2" Margin="90,10,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Center" VerticalContentAlignment="Center" Background="{Binding Background, ElementName=expander_file}" Height="30" HorizontalAlignment="Left" Width="550"/>

        <!-- 第四行：输出日志标签和日志文本框 -->
        <Label Content="输出日志：" Grid.Row="3" Margin="10,10,0,0" FontSize="16" HorizontalAlignment="Left" Width="80"/>

        <!-- 日志区域 -->
        <ScrollViewer x:Name="scroll_log" Grid.Row="3" Margin="10,40,0,10" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Padding="-7,0,0,0">
            <TextBox x:Name="tb_log" TextWrapping="Wrap" Text="TextBox" Background="{Binding Background, ElementName=expander_file}" IsReadOnly="True" BorderThickness="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" MinHeight="200"/>
        </ScrollViewer>

        <!-- 右侧按钮组 -->
        <StackPanel Grid.Row="1" Grid.RowSpan="4" Margin="655,10,0,10" HorizontalAlignment="Left" Width="136">
            <Button Content="添加文件" Height="48" FontSize="16" FontWeight="Bold" Click="Select_Click" Margin="0,0,0,10"/>
            <Button Content="输出目录" Height="48" FontSize="16" FontWeight="Bold" Click="Dir_Click" Margin="0,0,0,10"/>
            <Button Content="清空文件列表" Height="48" FontSize="16" FontWeight="Bold" Click="ClearFile_Click" Margin="0,0,0,10"/>
            <Button Content="清除运行日志" Height="48" FontSize="16" FontWeight="Bold" Click="ClearLog_Click" Margin="0,0,0,10"/>
            <Button Content="打开输出目录" Height="48" FontSize="16" FontWeight="Bold" Click="OpenDir_Click" Margin="0,0,0,10"/>
            <Button Content="开始执行" Height="48" FontSize="16" FontWeight="Bold" Click="Start_Click" Margin="0,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
